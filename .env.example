# Copy this to `.env` and fill in the values before running docker compose.
# In production, put these in a secrets manager or systemd EnvironmentFile
# instead of a plaintext file on disk.

# `web` enables OAuth login. `local` (or unset) keeps the single-user model.
TAIKO_TRAINER_MODE=web

# From https://osu.ppy.sh/home/account/edit → OAuth. The redirect URI must
# match exactly (scheme, host, port, path).
OSU_OAUTH_CLIENT_ID=
OSU_OAUTH_CLIENT_SECRET=
OSU_OAUTH_REDIRECT_URI=https://your-domain.example.com/oauth/callback

# Signs session cookies. Any long random string; leaking it lets an attacker
# forge sessions. Rotate = every existing user logs out.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=
